PORT=3001
DATABASE_URL=postgresql://user:password@localhost:5432/tafryt
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=30d

# Web Push (ייצר עם: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@example.com

# אחסון תמונות
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# כתובת הפרונטאנד (לקישורי הזמנה)
CLIENT_URL=http://localhost:5173
